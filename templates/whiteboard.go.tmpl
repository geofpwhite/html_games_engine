<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Whiteboard</title>
  <style>
    body {
      margin: 0;
      background: #1a1a2e;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    #toolbar {
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 10px 20px;
      background: #16213e;
      width: 100%;
      box-sizing: border-box;
    }

    #toolbar label {
      color: #eee;
      font-family: sans-serif;
      font-size: 14px;
    }

    #whiteboard {
      cursor: crosshair;
      border: 2px solid #0f3460;
      background: white;
      margin-top: 10px;
    }
  </style>
</head>

<body>
  {{ template "navbar" . }}

  <div id="toolbar">
    <label>Color: <input type="color" id="colorPicker" value="#000000"></label>
    <label>Brush: <input type="range" id="brushSize" min="1" max="20" value="3"></label>
  </div>

  <canvas id="whiteboard" width="800" height="600"></canvas>

  <script>
    const gamecode = window.location.href.split("ard/")[1];
    const socket = new WebSocket("wss://geof.geofpwhite.us/games/whiteboard/ws/" + gamecode);

    const canvas = document.getElementById("whiteboard");
    const ctx = canvas.getContext("2d");
    let isDrawing = false;

    socket.onmessage = (event) => {
      const obj = JSON.parse(event.data);
      if (obj.type === "full") {
        const img = new Image();
        img.onload = () => ctx.drawImage(img, 0, 0);
        img.src = "data:image/png;base64," + obj.png;
      } else if (obj.type === "delta") {
        ctx.fillStyle = "rgba(" + obj.r + "," + obj.g + "," + obj.b + "," + (obj.a / 255) + ")";
        ctx.beginPath();
        ctx.arc(obj.x, obj.y, obj.radius, 0, Math.PI * 2);
        ctx.fill();
      }
    };

    function sendDraw(x, y) {
      const color = document.getElementById("colorPicker").value.slice(1);
      const radius = parseInt(document.getElementById("brushSize").value);
      socket.send("d:" + x + "-" + y + "-" + color + "-" + radius);
    }

    function getPos(e) {
      const rect = canvas.getBoundingClientRect();
      return {
        x: Math.floor(e.clientX - rect.left),
        y: Math.floor(e.clientY - rect.top)
      };
    }

    canvas.addEventListener("mousedown", (e) => {
      isDrawing = true;
      const pos = getPos(e);
      sendDraw(pos.x, pos.y);
    });

    canvas.addEventListener("mousemove", (e) => {
      if (!isDrawing) return;
      const pos = getPos(e);
      sendDraw(pos.x, pos.y);
    });

    canvas.addEventListener("mouseup", () => isDrawing = false);
    canvas.addEventListener("mouseleave", () => isDrawing = false);
  </script>
</body>

</html>
