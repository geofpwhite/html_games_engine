<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Whiteboard</title>
  <style>
    body {
      margin: 0;
      background: #1a1a2e;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    #toolbar {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 10px 20px;
      background: #16213e;
      width: 100%;
      box-sizing: border-box;
      flex-wrap: wrap;
    }

    #toolbar label {
      color: #eee;
      font-family: sans-serif;
      font-size: 14px;
    }

    #toolbar select {
      background: #0f3460;
      color: #eee;
      border: 1px solid #4a6fa5;
      border-radius: 4px;
      padding: 4px 8px;
      font-size: 14px;
    }

    #toolbar button {
      background: #c0392b;
      color: white;
      border: none;
      border-radius: 4px;
      padding: 6px 14px;
      font-size: 14px;
      cursor: pointer;
    }

    #toolbar button:hover {
      background: #e74c3c;
    }

    #rotation-group {
      display: none;
      align-items: center;
      gap: 8px;
    }

    #filled-group {
      display: none;
      align-items: center;
      gap: 8px;
    }

    #canvas-wrap {
      position: relative;
      margin-top: 10px;
    }

    #whiteboard {
      cursor: crosshair;
      border: 2px solid #0f3460;
      background: white;
      display: block;
    }

    #preview {
      position: absolute;
      top: 0;
      left: 0;
      pointer-events: none;
    }
  </style>
</head>

<body>
  {{ template "navbar" . }}

  <div id="toolbar">
    <label>Color: <input type="color" id="colorPicker" value="#000000"></label>
    <label>Size: <input type="range" id="brushSize" min="1" max="40" value="3"></label>
    <label>Tool:
      <select id="toolSelect">
        <option value="draw">Draw</option>
        <option value="line">Line</option>
        <option value="rect">Rectangle</option>
        <option value="circle">Circle</option>
      </select>
    </label>
    <span id="rotation-group">
      <label style="color:#eee;font-family:sans-serif;font-size:14px;">
        Rotate: <input type="range" id="rotAngle" min="0" max="360" value="0" style="width:80px">
      </label>
      <span id="rotLabel" style="color:#eee;font-family:sans-serif;font-size:14px;">0°</span>
    </span>
    <span id="filled-group">
      <label style="color:#eee;font-family:sans-serif;font-size:14px;">
        <input type="checkbox" id="filledCheck"> Filled
      </label>
    </span>
    <button id="clearBtn">Clear</button>
  </div>

  <div id="canvas-wrap">
    <canvas id="whiteboard" width="800" height="600"></canvas>
    <canvas id="preview" width="800" height="600"></canvas>
  </div>

  <script>
    const gamecode = window.location.href.split("ard/")[1];
    const socket = new WebSocket("wss://geof.geofpwhite.us/games/whiteboard/ws/" + gamecode);

    const canvas = document.getElementById("whiteboard");
    const ctx = canvas.getContext("2d");
    const preview = document.getElementById("preview");
    const pctx = preview.getContext("2d");

    let isDrawing = false;
    let prevHolding = {};
    let isHolding = false;
    let startX = 0, startY = 0;

    const toolSelect = document.getElementById("toolSelect");
    const rotationGroup = document.getElementById("rotation-group");
    const filledGroup = document.getElementById("filled-group");
    const rotAngle = document.getElementById("rotAngle");
    const rotLabel = document.getElementById("rotLabel");

    toolSelect.addEventListener("change", () => {
      const t = toolSelect.value;
      rotationGroup.style.display = t === "rect" ? "flex" : "none";
      filledGroup.style.display = t === "circle" ? "flex" : "none";
    });

    rotAngle.addEventListener("input", () => {
      rotLabel.textContent = rotAngle.value + "°";
    });

    document.getElementById("clearBtn").addEventListener("click", () => {
      socket.send("c:");
    });

    socket.onmessage = (event) => {
      const obj = JSON.parse(event.data);
      if (obj.type === "full") {
        const img = new Image();
        img.onload = () => {
          canvas.width = img.naturalWidth;
          canvas.height = img.naturalHeight;
          preview.width = img.naturalWidth;
          preview.height = img.naturalHeight;
          ctx.drawImage(img, 0, 0);
        };
        img.src = "data:image/png;base64," + obj.png;
      } else if (obj.type === "delta") {
        ctx.fillStyle = "rgba(" + obj.r + "," + obj.g + "," + obj.b + "," + (obj.a / 255) + ")";
        ctx.beginPath();
        ctx.arc(obj.x, obj.y, obj.radius, 0, Math.PI * 2);
        ctx.fill();
      }
    };

    function hexColor() {
      return document.getElementById("colorPicker").value.slice(1);
    }

    function brushSize() {
      return parseInt(document.getElementById("brushSize").value);
    }

    function sendDraw(x, y) {
      socket.send("d:" + x + "-" + y + "-" + hexColor() + "-" + brushSize());
    }

    function sendShape(x1, y1, x2, y2) {
      const tool = toolSelect.value;
      const clr = hexColor();
      const thickness = brushSize();

      if (tool === "line") {
        socket.send("l:" + x1 + "-" + y1 + "-" + x2 + "-" + y2 + "-" + clr + "-" + thickness);
      } else if (tool === "rect") {
        const theta = parseFloat(rotAngle.value);
        socket.send("r:" + x1 + "-" + y1 + "-" + x2 + "-" + y2 + "-" + clr + "-" + thickness + "-" + theta);
      } else if (tool === "circle") {
        const dx = x2 - x1, dy = y2 - y1;
        const radius = Math.max(1, Math.round(Math.sqrt(dx * dx + dy * dy)));
        const filled = document.getElementById("filledCheck").checked ? "1" : "0";
        socket.send("ci:" + x1 + "-" + y1 + "-" + radius + "-" + clr + "-" + filled);
      }
    }

    function drawPreview(x1, y1, x2, y2) {
      pctx.clearRect(0, 0, preview.width, preview.height);
      const tool = toolSelect.value;
      const clr = "#" + hexColor();
      const thickness = brushSize();
      pctx.strokeStyle = clr;
      pctx.fillStyle = clr;
      pctx.lineWidth = thickness/2;

      if (tool === "line") {
        pctx.beginPath();
        pctx.moveTo(x1, y1);
        pctx.lineTo(x2, y2);
        pctx.stroke();
      } else if (tool === "rect") {
        const theta = parseFloat(rotAngle.value) * Math.PI / 180;
        pctx.save();
        const cx = (x1 + x2) / 2, cy = (y1 + y2) / 2;
        pctx.translate(cx, cy);
        pctx.rotate(theta);
        pctx.strokeRect(x1 - cx, y1 - cy, x2 - x1, y2 - y1);
        pctx.restore();
      } else if (tool === "circle") {
        const dx = x2 - x1, dy = y2 - y1;
        const radius = Math.sqrt((dx * dx) + (dy * dy));
        const filled = document.getElementById("filledCheck").checked;
        pctx.beginPath();
        pctx.arc(x1, y1, radius, 0, Math.PI * 2);
        if (filled) {
          pctx.fill();
        } else {
          pctx.stroke();
        }
      }
    }

    function getPos(e) {
      const rect = canvas.getBoundingClientRect();
      return {
        x: Math.floor(e.clientX - rect.left),
        y: Math.floor(e.clientY - rect.top)
      };
    }

    canvas.addEventListener("mousedown", (e) => {
      isDrawing = true;
      const pos = getPos(e);
      startX = pos.x;
      startY = pos.y;
      if (toolSelect.value === "draw") {
        sendDraw(pos.x, pos.y);
        if (isHolding && prevHolding != {}) 
          socket.send("l:" + pos.x + "-" + pos.y + "-" + prevHolding.x + "-" + prevHolding.y + "-" + hexColor() + "-" + brushSize());
        isHolding = true
        prevHolding=pos
      }
    });

    canvas.addEventListener("mousemove", (e) => {
      if (!isDrawing) return;
      const pos = getPos(e);
      if (toolSelect.value === "draw") {
        sendDraw(pos.x, pos.y);
      } else {
        drawPreview(startX, startY, pos.x, pos.y);
      }
    });

    canvas.addEventListener("mouseup", (e) => {
      if (!isDrawing) return;
      isDrawing = false;
      isHolding = false;
      const pos = getPos(e);
      if (toolSelect.value !== "draw") {
        pctx.clearRect(0, 0, preview.width, preview.height);
        sendShape(startX, startY, pos.x, pos.y);
      }
    });

    canvas.addEventListener("mouseleave", () => {
      isDrawing = false;
      pctx.clearRect(0, 0, preview.width, preview.height);
    });
  </script>
</body>

</html>
